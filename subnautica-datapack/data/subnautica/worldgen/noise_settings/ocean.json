{
  "sea_level": 400,
  "ore_veins_enabled": false,
  "aquifers_enabled": false,
  "legacy_random_source": false,
  "disable_mob_generation": false,
  "default_block": {
    "Name": "minecraft:stone"
  },
  "default_fluid": {
    "Name": "minecraft:water",
    "Properties": { "level": "0" }
  },
  "noise": {
    "min_y": -512,
    "height": 1024,
    "size_horizontal": 1,
    "size_vertical": 2
  },
  "noise_router": {
    "continents": {
      "type": "minecraft:flat_cache",
      "argument": {
        "type": "minecraft:cache_2d",
        "argument": {
          "type": "minecraft:noise",
          "noise": "minecraft:continentalness",
          "xz_scale": 0.25,
          "y_scale": 0.0
        }
      }
    },
    "erosion": {
      "type": "minecraft:flat_cache",
      "argument": {
        "type": "minecraft:cache_2d",
        "argument": {
          "type": "minecraft:noise",
          "noise": "minecraft:erosion",
          "xz_scale": 0.25,
          "y_scale": 0.0
        }
      }
    },
    "weirdness": {
      "type": "minecraft:noise",
      "noise": "minecraft:ridge",
      "xz_scale": 0.25,
      "y_scale": 0.0
    },
    "ridges": {
      "type": "minecraft:noise",
      "noise": "minecraft:ridge",
      "xz_scale": 0.25,
      "y_scale": 0.0
    },
    "initial_density_without_jaggedness": {
      "type": "minecraft:add",
      "argument1": {
        "type": "minecraft:y_clamped_gradient",
        "from_y": 336,
        "to_y": 400,
        "from_value": -1.5,
        "to_value": 1.5
      },
      "argument2": {
        "type": "minecraft:noise",
        "noise": "minecraft:gravel",
        "xz_scale": 0.2,
        "y_scale": 0.3
      }
    },
    "final_density": {
      "type": "minecraft:clamp",
      "input": {
        "type": "minecraft:add",
        "argument1": {
          "type": "minecraft:y_clamped_gradient",
          "from_y": 336,
          "to_y": 400,
          "from_value": -1.5,
          "to_value": 1.5
        },
        "argument2": {
          "type": "minecraft:add",
          "argument1": {
            "type": "minecraft:noise",
            "noise": "minecraft:gravel",
            "xz_scale": 0.15,
            "y_scale": 0.25
          },
          "argument2": {
            "type": "minecraft:mul",
            "argument1": -0.85,
            "argument2": {
              "type": "minecraft:noise",
              "noise": "minecraft:continentalness",
              "xz_scale": 0.1,
              "y_scale": 0.0
            }
          }
        }
      },
      "min": -1.0,
      "max": 1.0
    },
    "temperature": {
      "type": "minecraft:noise",
      "noise": "minecraft:temperature",
      "xz_scale": 0.25,
      "y_scale": 0.0
    },
    "humidity": {
      "type": "minecraft:noise",
      "noise": "minecraft:vegetation",
      "xz_scale": 0.25,
      "y_scale": 0.0
    },
    "offset": 0.0,
    "factor": 0.0,
    "jaggedness": 0.0,
    "depth": 0.0,
    "barrier": 0.0,
    "fluid_level_floodedness": 0.0,
    "fluid_level_spread": 0.0,
    "lava": 0.0,
    "vein_gap": 0.0,
    "vein_ridged": 0.0,
    "vein_toggle": 0.0,
    "preliminary_surface_level": 0.0,
    "vegetation": 0.0
  },
  "spawn_target": [],
  "surface_rule": {
    "type": "minecraft:sequence",
    "sequence": [
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:stone_depth",
          "surface_type": "floor",
          "add_surface_depth": false,
          "secondary_depth_range": 0,
          "offset": 0
        },
        "then_run": {
          "type": "minecraft:sequence",
          "sequence": [
            {
              "type": "minecraft:condition",
              "if_true": { "type": "minecraft:biome", "biome_is": ["subnautica:safe_shallows"] },
              "then_run": { "type": "minecraft:block", "result_state": { "Name": "minecraft:sand" } }
            },
            {
              "type": "minecraft:condition",
              "if_true": { "type": "minecraft:biome", "biome_is": ["subnautica:kelp_forest", "subnautica:blood_kelp", "subnautica:open_ocean"] },
              "then_run": { "type": "minecraft:block", "result_state": { "Name": "minecraft:gravel" } }
            },
            {
              "type": "minecraft:condition",
              "if_true": { "type": "minecraft:biome", "biome_is": ["subnautica:lost_river"] },
              "then_run": { "type": "minecraft:block", "result_state": { "Name": "minecraft:clay" } }
            },
            {
              "type": "minecraft:condition",
              "if_true": { "type": "minecraft:biome", "biome_is": ["subnautica:inactive_lava"] },
              "then_run": { "type": "minecraft:block", "result_state": { "Name": "minecraft:basalt" } }
            },
            {
              "type": "minecraft:condition",
              "if_true": { "type": "minecraft:biome", "biome_is": ["subnautica:lava_zones", "subnautica:primary_lava"] },
              "then_run": { "type": "minecraft:block", "result_state": { "Name": "minecraft:magma_block" } }
            },
            {
              "type": "minecraft:condition",
              "if_true": { "type": "minecraft:biome", "biome_is": ["subnautica:island_oak", "subnautica:island_cherry", "subnautica:island_jungle", "subnautica:island_savanna"] },
              "then_run": { "type": "minecraft:block", "result_state": { "Name": "minecraft:grass_block", "Properties": { "snowy": "false" } } }
            },
            {
              "type": "minecraft:condition",
              "if_true": { "type": "minecraft:biome", "biome_is": ["subnautica:island_spruce"] },
              "then_run": { "type": "minecraft:block", "result_state": { "Name": "minecraft:snow_block" } }
            },
            {
              "type": "minecraft:block",
              "result_state": { "Name": "minecraft:stone" }
            }
          ]
        }
      },
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:stone_depth",
          "surface_type": "floor",
          "add_surface_depth": true,
          "secondary_depth_range": 3,
          "offset": 0
        },
        "then_run": {
          "type": "minecraft:sequence",
          "sequence": [
            {
              "type": "minecraft:condition",
              "if_true": { "type": "minecraft:biome", "biome_is": ["subnautica:safe_shallows"] },
              "then_run": { "type": "minecraft:block", "result_state": { "Name": "minecraft:sand" } }
            },
            {
              "type": "minecraft:condition",
              "if_true": { "type": "minecraft:biome", "biome_is": ["subnautica:island_oak", "subnautica:island_cherry", "subnautica:island_jungle", "subnautica:island_savanna"] },
              "then_run": { "type": "minecraft:block", "result_state": { "Name": "minecraft:dirt" } }
            }
          ]
        }
      }
    ]
  }
}
